# ─── Maxio Advanced Billing ────────────────────────────────────────────────
MAXIO_API_KEY=your_maxio_api_key
MAXIO_SITE_SUBDOMAIN=your-test-site
MAXIO_ENVIRONMENT=US

# ─── Slack (bot-token app) ──────────────────────────────────────────────────
# Bot token from your Slack app (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# OAuth credentials for the Slack SDK client constructor
SLACK_OAUTH_CLIENT_ID=your_slack_oauth_client_id
SLACK_OAUTH_CLIENT_SECRET=your_slack_oauth_client_secret
SLACK_OAUTH_REDIRECT_URI=http://localhost:4000/oauth/callback

# Channel ID for the consultant digest (e.g. C0XXXXXXX)
SLACK_DIGEST_CHANNEL=

# ─── Demo consultants (must be real members of your Slack workspace) ─────────
CONSULTANT_1_NAME=Alice Chen
CONSULTANT_1_EMAIL=alice@yourworkspace.com
CONSULTANT_2_NAME=Bob Martinez
CONSULTANT_2_EMAIL=bob@yourworkspace.com

# ─── Admin (placeholder auth) ───────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# ─── App ────────────────────────────────────────────────────────────────────
PORT=4000
SESSION_TTL_MINUTES=30

# ─── Seed: EBB metric for api-calls component ────────────────────────────────
# Create an Event-Based Billing metric in the Maxio UI first:
#   Advanced Billing → Settings → Event-Based Billing → New Metric
#   Name: "API Calls", unit name: "api call"
# Then paste the numeric metric ID here.
MAXIO_API_CALLS_METRIC_ID=
